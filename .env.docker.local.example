# Copy to .env.docker.local (gitignored) and fill in your Passport keys.
# Use single-line PEM with \n between lines — Docker env_file cannot parse multi-line values.
#
# PASSPORT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----"
# PASSPORT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIC...\n-----END PUBLIC KEY-----"
#
# Alternative — mount secret files (see docker-compose.yml comments):
# PASSPORT_PRIVATE_KEY_FILE=/run/secrets/passport_private_key
# PASSPORT_PUBLIC_KEY_FILE=/run/secrets/passport_public_key
