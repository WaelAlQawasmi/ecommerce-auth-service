# =============================================================================
# Production with AWS RDS (external PostgreSQL)
#
# Copy to .env.docker.local on your production server (gitignored):
#   cp .env.docker.production.example .env.docker.local
#
# Then fill in your RDS endpoint and credentials. Start with:
#   bash run-production.sh        (Linux/macOS)
#   run-production.bat            (Windows)
#   make up                       (if Makefile is available)
#
# DOCKER_DB_ENABLED=false skips the bundled postgres container entirely.
# App containers connect to RDS over the Docker egress network.
# =============================================================================

DOCKER_DB_ENABLED=false

DB_CONNECTION=pgsql
DB_HOST=your-instance.region.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=ecommerce_auth
DB_USERNAME=auth_user
DB_PASSWORD=your_rds_password

# Optional: restrict app debug in production
APP_ENV=production
APP_DEBUG=false

# Nginx host port (default 8080; use 80 behind a load balancer if needed)
# NGINX_HOST_PORT=80
