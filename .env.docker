# =============================================================================
# .env.docker — Docker Compose environment variables
#
# ⚠️  IMPORTANT:
#   - This file is used by docker-compose.yml at runtime.
#   - DO NOT commit real secrets to version control.
#   - For production, replace all placeholder values with secrets from your
#     secrets manager (AWS Secrets Manager, Vault, Docker Secrets, etc.).
#   - Copy this file to .env.docker.local and override values locally —
#     .env.docker.local is excluded by .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="Ecommerce Auth Service"
APP_ENV=production
# Generate a real key with: php artisan key:generate --show
APP_KEY=base64:qjonCCO2AI1/ZDpkXVaKAUZva2QSbyGYMG1/awu8jqk=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging — use stderr/stdout so Docker captures logs natively
# ---------------------------------------------------------------------------
LOG_CHANNEL=stderr
LOG_LEVEL=error            # info or debug for staging; error for production

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ecommerce_auth
DB_USERNAME=auth_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD          # ← change this
DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD # ← change this

# ---------------------------------------------------------------------------
# Session — use Redis for shared session state across multiple app containers
# ---------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ---------------------------------------------------------------------------
# Queue & Cache — backed by Redis for performance
# ---------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=ecommerce_auth_

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD  # ← change this; must match redis.conf

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit          # use mailpit or mailhog for local dev
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@ecommerce-auth.local
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# AWS S3 (optional — for file storage)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Nginx host port (override to avoid conflicts with other local services)
# ---------------------------------------------------------------------------
NGINX_HOST_PORT=8080

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_VERSION=v1
API_DOCS_ENABLED=true

# OAuth2 password-grant client (optional — seeder writes to storage if unset)
PASSPORT_PASSWORD_CLIENT_ID=
PASSPORT_PASSWORD_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Passport signing keys (centralized — MUST be identical on every instance)
# ---------------------------------------------------------------------------
# Cloud/production: store the PEM contents in your secrets manager and inject
# them here on app, queue, and scheduler. When both are set, keys are never
# regenerated and all replicas validate the same tokens.
#
# Local dev: copy .env.docker.local.example → .env.docker.local (gitignored).
# Set single-line PEM with \n escapes — multi-line values break Docker env_file.
