#
# Generate once:
#   docker compose exec app php artisan passport:keys --force
#   docker compose exec app cat storage/oauth-private.key
#   docker compose exec app cat storage/oauth-public.key
# Or run: php docker/scripts/migrate-passport-keys-to-local.php (after pasting PEM)
#
# Alternative — mount Docker/K8s secret files (entrypoint copies to storage):
# PASSPORT_PRIVATE_KEY_FILE=/run/secrets/passport_private_key
# PASSPORT_PUBLIC_KEY_FILE=/run/secrets/passport_public_key
