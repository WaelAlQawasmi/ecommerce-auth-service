[mysqld]
# =============================================================================
# MySQL 8.4 configuration — ecommerce-auth-service
#
# Mounted read-only at /etc/mysql/conf.d/app.cnf
# Official MySQL 8 image picks up all files in conf.d automatically.
# =============================================================================

# ---------------------------------------------------------------------------
# Basic settings
# ---------------------------------------------------------------------------
pid_file                = /var/run/mysqld/mysqld.pid
socket                  = /var/run/mysqld/mysqld.sock
datadir                 = /var/lib/mysql

# Route all logs to stderr so Docker captures them
# MySQL 8.4 supports logging to a file descriptor via log_error_services
log_error               = /dev/stderr
log_error_verbosity     = 2

# ---------------------------------------------------------------------------
# Character set & collation
# ---------------------------------------------------------------------------
character_set_server    = utf8mb4
collation_server        = utf8mb4_0900_ai_ci   # MySQL 8 default — faster than unicode_ci

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------
bind_address            = 0.0.0.0    # accept connections from the Docker network
max_connections         = 150
max_allowed_packet      = 64M
thread_stack            = 256K
thread_cache_size       = 16

# ---------------------------------------------------------------------------
# InnoDB — the only storage engine you should use
# ---------------------------------------------------------------------------
default_storage_engine  = InnoDB

# Buffer pool: primary caching layer for InnoDB data + indexes.
# Rule of thumb: 60–70% of available RAM for a dedicated DB container.
# Container limit is 512 MB → 320 MB is reasonable.
innodb_buffer_pool_size         = 320M
innodb_buffer_pool_instances    = 4      # parallel I/O threads (1 per 1 GB, min 1)

# Redo log capacity (MySQL 8.4 uses innodb_redo_log_capacity instead of
# the old innodb_log_file_size / innodb_log_files_in_group pair)
innodb_redo_log_capacity        = 256M

# O_DIRECT bypasses OS file cache for data files; avoids double-caching
innodb_flush_method             = O_DIRECT

# One ibd file per table — easier backup and recovery
innodb_file_per_table           = ON

# Flush strategy: 2 = flush log to OS each second, flush data on checkpoint
# (best performance; durability risk = up to 1 second of commits on crash)
innodb_flush_log_at_trx_commit  = 1    # set to 2 only if you can tolerate 1 s data loss
sync_binlog                     = 1

# ---------------------------------------------------------------------------
# Slow query log — helps identify N+1 and missing-index problems
# ---------------------------------------------------------------------------
slow_query_log          = ON
slow_query_log_file     = /dev/stderr
long_query_time         = 1          # flag queries slower than 1 second
log_queries_not_using_indexes = OFF  # enable in dev to catch full-table scans

# ---------------------------------------------------------------------------
# Binary log — required for point-in-time recovery and replication
# Disable if you are certain you will never need either.
# ---------------------------------------------------------------------------
# server_id               = 1
# log_bin                 = /var/log/mysql/mysql-bin.log
# binlog_expire_logs_seconds = 604800   # 7 days
# max_binlog_size         = 100M

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Disable LOAD DATA LOCAL INFILE to prevent data exfiltration attacks
local_infile            = OFF

# Use the recommended caching_sha2_password authentication plugin (MySQL 8 default)
default_authentication_plugin = caching_sha2_password

# ---------------------------------------------------------------------------
# NOTE: query_cache_* settings are REMOVED — they were deprecated in MySQL 5.7
# and fully removed in MySQL 8.0. Do not add them back.
# ---------------------------------------------------------------------------

[mysqldump]
quick
quote_names
max_allowed_packet = 64M
