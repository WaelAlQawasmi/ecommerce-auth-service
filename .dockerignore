# =============================================================================
# .dockerignore — ecommerce-auth-service
#
# Excludes files from the Docker build context.
# Smaller context = faster builds and no risk of leaking secrets into images.
# =============================================================================

# ---------------------------------------------------------------------------
# Version control
# ---------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# ---------------------------------------------------------------------------
# Environment / secrets — NEVER bake these into images
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example        # keep the example file as documentation

# ---------------------------------------------------------------------------
# Docker files themselves (not needed inside the image)
# ---------------------------------------------------------------------------
Dockerfile
docker-compose*.yml
.dockerignore
docker-start.*
DOCKER.md

# ---------------------------------------------------------------------------
# Dependency directories — rebuilt inside the image from manifests
# ---------------------------------------------------------------------------
vendor/
node_modules/

# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
public/hot
public/build
public/mix-manifest.json

# ---------------------------------------------------------------------------
# Storage — runtime data, never part of the image
# ---------------------------------------------------------------------------
storage/logs/
storage/testing/
storage/framework/sessions/
storage/framework/cache/
storage/framework/views/

# Bootstrap cache — regenerated by entrypoint
bootstrap/cache/

# ---------------------------------------------------------------------------
# Test / development artefacts
# ---------------------------------------------------------------------------
tests/
phpunit.xml
phpunit.xml.dist
.phpunit.result.cache
.phpunit.cache/

# ---------------------------------------------------------------------------
# Editor / IDE metadata
# ---------------------------------------------------------------------------
.editorconfig
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# CI / tooling configuration
# ---------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
Makefile

# ---------------------------------------------------------------------------
# Documentation
# ---------------------------------------------------------------------------
README.md
QUICKSTART.md
CHANGELOG.md
CONTRIBUTING.md
*.md

# ---------------------------------------------------------------------------
# Log files
# ---------------------------------------------------------------------------
*.log
php_errors.log

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.npmrc
.pytest_cache/
