# =============================================================================
# Production environment — EC2 deploy (/opt/.env)
#
# Copy on the EC2 server (never commit real secrets):
#   sudo cp .env.production.example /opt/.env
#   sudo nano /opt/.env
#   sudo chmod 600 /opt/.env
#
# Rules for docker --env-file:
#   - One KEY=value per line
#   - No inline comments on the same line as a value
#   - PEM keys: single line with \n escapes (see PASSPORT_* below)
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="Ecommerce Auth Service"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=http://YOUR_EC2_PUBLIC_IP:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Database (AWS RDS PostgreSQL)
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=your-instance.region.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=ecommerce_auth
DB_USERNAME=auth_user
DB_PASSWORD=your_rds_password

# ---------------------------------------------------------------------------
# Redis (AWS ElastiCache or container named "redis" on auth-net)
# ---------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=ecommerce_auth_

REDIS_CLIENT=phpredis
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_VERSION=v1
API_DOCS_ENABLED=false

# ---------------------------------------------------------------------------
# Passport (OAuth2 / JWT signing)
# Generate once locally, then paste as single-line PEM with \n escapes:
#   docker compose exec app php artisan passport:keys --force
#   php docker/scripts/migrate-passport-keys-to-local.php
# ---------------------------------------------------------------------------
PASSPORT_PASSWORD_CLIENT_ID=
PASSPORT_PASSWORD_CLIENT_SECRET=
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
